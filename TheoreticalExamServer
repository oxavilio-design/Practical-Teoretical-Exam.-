local function getServerTime()
	local ok, value = pcall(function() return Workspace:GetServerTimeNow() end)
	if ok and typeof(value) == "number" then return value end
	return os.clock()
end

local function cloneOptions(options)
	if type(options) ~= "table" then return nil end
	local clone = {}
	for key, value in pairs(options) do
		clone[key] = value
	end
	return clone
end

local function shuffle(array)
	for index = #array, 2, -1 do
		local swapIndex = rng:NextInteger(1, index)
		array[index], array[swapIndex] = array[swapIndex], array[index]
	end
end

local function getTimeLimit(questionType)
	return questionType == "Specialist" and Config.SpecialistTimeLimit or Config.BasicTimeLimit
end

local function normalizeQuestion(question)
	if type(question) ~= "table" then return nil end

	local questionType = question.Type
	if questionType ~= "Basic" and questionType ~= "Specialist" then return nil end

	local id = tonumber(question.Id)
	local text = tostring(question.Text or "")
	if not id or text == "" then return nil end

	local points = tonumber(question.Points)
	if points == nil then
		points = (questionType == "Basic") and 2 or 3
	end

	return {
		Id = id,
		Text = text,
		Type = questionType,
		Points = math.max(1, math.floor(points + 0.5)),
		ImageId = (type(question.ImageId) == "string" and question.ImageId ~= "") and question.ImageId or Config.DefaultImage,
		Options = cloneOptions(question.Options),
		CorrectAnswer = question.CorrectAnswer,
	}
end

local function answersMatch(question, left, right)
	if question.Type == "Basic" then
		return type(left) == "boolean" and type(right) == "boolean" and left == right
	end
	return type(left) == "string" and type(right) == "string" and left == right
end

local function selectionIsValid(question, answer)
	if question.Type == "Basic" then
		return type(answer) == "boolean"
	end
	return type(answer) == "string" and (answer == "A" or answer == "B" or answer == "C")
end

local function resolvePromptHost(instance)
	if instance:IsA("BasePart") then return instance end
	local rootPart = instance:FindFirstChild("HumanoidRootPart")
	if rootPart and rootPart:IsA("BasePart") then return rootPart end
	if instance.PrimaryPart and instance.PrimaryPart:IsA("BasePart") then return instance.PrimaryPart end

	for _, descendant in ipairs(instance:GetDescendants()) do
		if descendant:IsA("BasePart") then return descendant end
	end
	return nil
end

