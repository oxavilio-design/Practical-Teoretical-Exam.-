local function copyOptions(options)
	if type(options) ~= "table" then
		return nil
	end

	local copy = {}
	for key, value in pairs(options) do
		copy[key] = value
	end
	return copy
end

local module = {}

function module.GetAllQuestions()
	local copy = table.create(#Questions)
	for index, question in ipairs(Questions) do
		copy[index] = {
			Id = question.Id,
			Text = question.Text,
			Type = question.Type,
			Points = question.Points,
			ImageId = question.ImageId,
			Options = copyOptions(question.Options),
			CorrectAnswer = question.CorrectAnswer,
		}
	end
	return copy
end

module.Questions = Questions

return module
